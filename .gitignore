# Personal/private configs
.private/

# Personal/local CLAUDE.md overrides (Claude Code's native pattern for
# per-machine instructions that shouldn't ship to users). Public CLAUDE.md
# is tracked; local variants are not.
CLAUDE.local.md

# Per-user Claude Code settings (permissions, hooks, etc.). Project-wide
# settings at .claude/settings.json are fine to commit; .local.json is
# personal and should not ship.
.claude/settings.local.json

# Instance state (tracked per-instance, not in framework)
.applied-updates

# OS junk
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.vscode/
.idea/
