#!/usr/bin/env bash
# llm-secrets - Store and manage environment variable secrets
#
# Usage:
#   llm-secrets                          Interactive mode (prompts for everything)
#   llm-secrets set "my github pat"      Set a secret by name
#   llm-secrets list                     List secret names (not values)
#   llm-secrets remove MY_VAR_NAME       Remove a secret
#   llm-secrets help                     Show this help
#
# Secrets are stored in ~/.secrets (chmod 600) and sourced by your shell
# on startup. Values never appear in terminal output or command history.

SECRETS_FILE="${SECRETS_FILE:-$HOME/.secrets}"

ensure_file() {
    if [ ! -f "$SECRETS_FILE" ]; then
        touch "$SECRETS_FILE"
        chmod 600 "$SECRETS_FILE"
    fi
}

# Convert natural name to ENV_VAR format
# "my github pat" -> MY_GITHUB_PAT
# "gh pat iamfoehammer" -> GH_PAT_IAMFOEHAMMER
# "MY_VAR" -> MY_VAR (already formatted, leave it)
to_var_name() {
    local input="$*"
    # POSIX -E regex; -P (Perl) was GNU-only and broke on BSD/macOS.
    if echo "$input" | grep -qE '^[A-Z_][A-Z0-9_]*$'; then
        echo "$input"
        return
    fi
    # sed -E enables ERE so `+` (one-or-more) works on both GNU and BSD;
    # the previous BRE form `\+` was a GNU extension.
    echo "$input" | sed -E 's/[[:space:]-]+/_/g; s/[^A-Za-z0-9_]//g' | tr '[:lower:]' '[:upper:]'
}

copy_to_clipboard() {
    local text="$1"
    if [ -f /mnt/c/Windows/System32/clip.exe ]; then
        printf '%s' "$text" | /mnt/c/Windows/System32/clip.exe
    elif command -v pbcopy &>/dev/null; then
        printf '%s' "$text" | pbcopy
    elif command -v wl-copy &>/dev/null; then
        # Wayland - now the default on Fedora 36+, Ubuntu 22.04+ GNOME,
        # and most modern Linux desktop sessions. Check before xclip so
        # wl-copy isn't shadowed when both happen to be installed.
        printf '%s' "$text" | wl-copy
    elif command -v xclip &>/dev/null; then
        printf '%s' "$text" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        # Some minimal X11 installs ship xsel instead of xclip.
        printf '%s' "$text" | xsel --clipboard --input
    fi
}

cmd_set() {
    local raw_name="$*"

    # If no name provided, prompt for it
    if [ -z "$raw_name" ]; then
        read -rp "What's the secret for? " raw_name
        if [ -z "$raw_name" ]; then
            echo "Aborted."
            exit 1
        fi
    fi

    # Convert to ENV_VAR format
    local var_name
    var_name=$(to_var_name "$raw_name")

    # Reject names that aren't valid shell identifiers. to_var_name can
    # produce empty (all-punctuation input like '!@#') or leading-digit
    # (input like '123foo') results that bash's `export` rejects with
    # "not a valid identifier" when ~/.secrets is later sourced - except
    # the rejection happens far from the user's `llm-secrets set` call,
    # so the failure mode looks like "my secrets file is corrupted"
    # rather than "my input was bad." Match the PS port's pre-iter-251
    # validation (llm-secrets.ps1 line 49) so both ports reject early.
    if ! echo "$var_name" | grep -qE '^[A-Z_][A-Z0-9_]*$'; then
        echo "Invalid variable name after conversion: '$var_name'"
        echo "Input '$raw_name' didn't produce a usable identifier."
        echo "Try a name with letters, numbers, or underscores (no leading digit)."
        exit 1
    fi

    # Show what it'll be called
    if [ "$var_name" != "$raw_name" ]; then
        echo "Variable name: $var_name"
    fi

    # Prompt for the secret value (hidden input)
    read -rsp "Paste secret value: " value
    echo ""
    if [ -n "$value" ]; then
        echo "(${#value} characters received)"
    fi

    if [ -z "$value" ]; then
        echo "No value provided. Aborted."
        exit 1
    fi

    ensure_file

    # Atomic write-then-rename so a kill mid-update can't leave the
    # secrets file in a "old entry removed, new entry not yet written"
    # state (the worst case: silent data loss for an existing secret).
    # Build the complete new content in a tmp file (filtered old +
    # new entry), set perms on the tmp, then rename. Same pattern as
    # iter-276 save_state.
    local was_present=no
    if grep -q "^export ${var_name}=" "$SECRETS_FILE" 2>/dev/null; then
        was_present=yes
    fi
    local tmp="$SECRETS_FILE.tmp.$$"
    # `|| :` keeps the script alive if grep finds nothing (rc=1).
    grep -v "^export ${var_name}=" "$SECRETS_FILE" > "$tmp" 2>/dev/null || :
    echo "export ${var_name}=\"${value}\"" >> "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$SECRETS_FILE"
    if [ "$was_present" = "yes" ]; then
        echo "(Updated existing secret)"
    fi

    # Copy variable reference to clipboard
    local var_ref="\$${var_name}"
    copy_to_clipboard "$var_ref"

    echo ""
    echo "Saved! Your variable is: $var_ref"
    echo "(already in your clipboard)"
    echo ""
    echo "Run 'source ~/.secrets' or open a new shell to load it."
}

cmd_list() {
    ensure_file
    if [ ! -s "$SECRETS_FILE" ]; then
        echo "No secrets stored."
        return
    fi
    echo "Stored secrets ($SECRETS_FILE):"
    # Pull NAME from "export NAME=value" lines. POSIX sed; the previous
    # `grep -oP '(?<=^export )...(?==)'` lookbehind/lookahead was GNU-only.
    sed -n 's/^export \([A-Za-z_][A-Za-z0-9_]*\)=.*$/\1/p' "$SECRETS_FILE" | while read -r name; do
        echo "  \$$name"
    done
}

cmd_remove() {
    local raw_name="$*"
    if [ -z "$raw_name" ]; then
        read -rp "Variable name to remove: " raw_name
        if [ -z "$raw_name" ]; then
            echo "Aborted."
            exit 1
        fi
    fi

    local var_name
    var_name=$(to_var_name "$raw_name")

    ensure_file

    if ! grep -q "^export ${var_name}=" "$SECRETS_FILE" 2>/dev/null; then
        echo "$var_name not found in $SECRETS_FILE"
        exit 1
    fi

    # Atomic write-then-rename: build new content (filtered) in a
    # PID-suffixed tmp file, then `mv` over the real file. Same
    # pattern as iter-277 cmd_set and iter-276 save_state. The 0-byte
    # case (removing the last secret) still needs explicit empty-
    # file handling - echo "" writes a stray newline (bash gotcha
    # #7) that defeats cmd_list's `[ -s ]` empty-file check, so a
    # user removing the last secret would see "Stored secrets:" with
    # no items under it.
    local tmp_path="$SECRETS_FILE.tmp.$$"
    local filtered
    filtered=$(grep -v "^export ${var_name}=" "$SECRETS_FILE")
    if [ -z "$filtered" ]; then
        : > "$tmp_path"
    else
        echo "$filtered" > "$tmp_path"
    fi
    chmod 600 "$tmp_path"
    mv "$tmp_path" "$SECRETS_FILE"

    echo "Removed $var_name"
    echo "Run 'source ~/.secrets' or open a new shell to unload it."
}

cmd_help() {
    echo ""
    echo "  llm-secrets - Store environment variable secrets securely"
    echo ""
    echo "  Commands:"
    echo "    llm-secrets                       Interactive (prompts for everything)"
    echo "    llm-secrets set                   Same as above"
    echo "    llm-secrets set 'my github pat'   Auto-converts to MY_GITHUB_PAT"
    echo "    llm-secrets list                  List secret names (not values)"
    echo "    llm-secrets remove VAR_NAME       Remove a secret"
    echo "    llm-secrets help                  Show this help"
    echo ""
    echo "  Secrets are stored in ~/.secrets (chmod 600)."
    echo "  Source it in your shell profile to load on startup."
    echo ""
}

# Default to interactive set mode (no args = "What's the secret for?")
case "${1:-set}" in
    set)    shift 2>/dev/null; cmd_set "$@" ;;
    list)   cmd_list ;;
    remove) shift; cmd_remove "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        # If they type something that's not a command, treat it as a name
        # e.g. "llm-secrets my github pat" works like "llm-secrets set my github pat"
        cmd_set "$@"
        ;;
esac
