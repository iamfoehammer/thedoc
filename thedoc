#!/usr/bin/env bash
# thedoc - Entry point for the Emergency Medical Hologram framework
# Usage:
#   thedoc          - Run setup (create or open a doctor instance)
#   thedoc setup    - Same as above
#   thedoc list     - List existing doctor instances
#   thedoc open     - Open an existing instance directly

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Locate the user's projects directory (where doctor instances live).
# Prefer the state file written by setup.sh - that's what the user actually
# chose. Fall back to the parent of the framework dir, which works when the
# user followed the bootstrap default of putting thedoc inside ~/GitHub/.
_state_file="${XDG_STATE_HOME:-$HOME/.local/state}/thedoc/state"
GITHUB_DIR=""
_state_projects=""
if [ -f "$_state_file" ]; then
    _state_projects=$(sed -n 's/^projects_dir=//p' "$_state_file" 2>/dev/null || true)
    # Strip trailing CR in case state was written by PS on Windows (CRLF);
    # sed otherwise preserves the \r and the [ -d ] check below fails.
    _state_projects="${_state_projects%$'\r'}"
    GITHUB_DIR="$_state_projects"
fi
if [ -z "$GITHUB_DIR" ] || [ ! -d "$GITHUB_DIR" ]; then
    GITHUB_DIR="$(dirname "$SCRIPT_DIR")"
fi
# Stash whether state pointed at a gone-away dir so the list/open
# subcommands can warn instead of silently showing nothing. Avoids the
# "I had three instances and they all vanished!" confusion.
_state_stale="no"
if [ -n "$_state_projects" ] && [ ! -d "$_state_projects" ]; then
    _state_stale="yes"
fi
unset _state_file _state_projects

case "${1:-setup}" in
    setup)
        exec "$SCRIPT_DIR/setup.sh"
        ;;
    test)
        # Run the framework's full test suite: wrapper tests (fast, non-PTY)
        # then the E2E smoke test (PTY-based, ~25s). Mirrors what CI runs
        # so `thedoc test` after `thedoc update` is a faithful local check.
        if [ ! -f "$SCRIPT_DIR/tests/test_wrapper.sh" ] || \
           [ ! -f "$SCRIPT_DIR/tests/smoke_test.py" ]; then
            echo ""
            echo "  Tests not found under $SCRIPT_DIR/tests/"
            echo "  Try 'thedoc update' to refresh the framework."
            echo ""
            exit 1
        fi
        if ! command -v python3 >/dev/null 2>&1; then
            echo ""
            echo "  thedoc test requires python3 for the smoke suite."
            echo "  Install it via your package manager and try again."
            echo ""
            exit 1
        fi
        bash "$SCRIPT_DIR/tests/test_wrapper.sh" || exit $?
        echo ""
        # Forward extra args (--keep-logs, --clean-logs, scenario names,
        # --list) so 'thedoc test --keep-logs happy-path' works the way
        # 'python3 tests/smoke_test.py --keep-logs happy-path' does.
        exec python3 "$SCRIPT_DIR/tests/smoke_test.py" "${@:2}"
        ;;
    update)
        # Pull the latest framework. Runs in the framework dir so it works
        # regardless of caller's cwd. Checks preconditions first so a user
        # who edited setup.sh locally (or has no upstream tracking) gets a
        # friendly message instead of git's raw error.
        if ! command -v git >/dev/null 2>&1; then
            echo ""
            echo "  thedoc update requires git."
            echo ""
            exit 1
        fi
        if [ ! -d "$SCRIPT_DIR/.git" ]; then
            echo ""
            echo "  $SCRIPT_DIR is not a git checkout - can't pull."
            echo "  If you installed via the bootstrap one-liner, this is a bug."
            echo ""
            exit 1
        fi
        # Dirty working tree blocks ff-only with an opaque error otherwise.
        if ! git -C "$SCRIPT_DIR" diff --quiet HEAD 2>/dev/null; then
            echo ""
            echo "  Local changes detected in $SCRIPT_DIR."
            echo "  Commit, stash, or revert them before running 'thedoc update'."
            echo ""
            echo "  Files changed:"
            git -C "$SCRIPT_DIR" status --short
            echo ""
            exit 1
        fi
        # No upstream tracking → git's error is cryptic ("no tracking
        # information"). Catch it early.
        if ! git -C "$SCRIPT_DIR" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
            echo ""
            echo "  Current branch has no upstream tracking."
            echo "  Set one up with:"
            echo "      git -C $SCRIPT_DIR branch --set-upstream-to=origin/main"
            echo ""
            exit 1
        fi
        echo ""
        echo "  Updating thedoc..."
        if git -C "$SCRIPT_DIR" pull --ff-only 2>&1; then
            echo ""
        else
            echo ""
            echo "  Pull failed. Your local history may have diverged from origin."
            echo "  Inspect with 'git -C $SCRIPT_DIR log --oneline @{u}..HEAD'."
            echo ""
            exit 1
        fi
        ;;
    list)
        echo ""
        if [ "$_state_stale" = "yes" ]; then
            echo "  Note: state's projects_dir is missing; falling back to $GITHUB_DIR/"
            echo "  (run 'thedoc setup' to point state at the right place)"
            echo ""
        fi
        echo "  Doctor instances in $GITHUB_DIR/:"
        echo ""
        found=0
        for dir in "$GITHUB_DIR"/*/; do
            # An instance is identified by a DOCTOR.md at its root.
            [ -f "$dir/DOCTOR.md" ] || continue
            name="$(basename "$dir")"
            # Read the explicit "Doctor type:" and "Created:" lines from
            # CLAUDE.md (written by setup.sh's CLAUDE.md generator).
            doctor_type="unknown"
            created=""
            if [ -f "$dir/CLAUDE.md" ]; then
                read_type=$(sed -n 's/^- \*\*Doctor type:\*\* //p' "$dir/CLAUDE.md" 2>/dev/null | head -1)
                [ -n "$read_type" ] && doctor_type="$read_type"
                # Pull the date portion only (strip the "T...Z" time part)
                read_created=$(sed -n 's/^- \*\*Created:\*\* //p' "$dir/CLAUDE.md" 2>/dev/null | head -1)
                [ -n "$read_created" ] && created="${read_created%%T*}"
            fi
            if [ -n "$created" ]; then
                echo "    $name  ($doctor_type, $created)"
            else
                echo "    $name  ($doctor_type)"
            fi
            found=1
        done
        if [ "$found" -eq 0 ]; then
            echo "    (none found - run 'thedoc setup' to create one)"
        fi
        echo ""
        ;;
    open)
        instance="${2:-}"
        if [ -z "$instance" ]; then
            echo "Usage: thedoc open <instance-name>"
            echo "Run 'thedoc list' to see available instances."
            exit 1
        fi
        instance_dir="$GITHUB_DIR/$instance"
        if [ ! -d "$instance_dir" ] || [ ! -f "$instance_dir/DOCTOR.md" ]; then
            echo "Not a doctor instance: $instance_dir"
            if [ "$_state_stale" = "yes" ]; then
                echo "(state's projects_dir is missing; using fallback $GITHUB_DIR/."
                echo " your instance may live at the old location instead.)"
            fi
            echo "Run 'thedoc list' to see available instances."
            exit 1
        fi
        # Pass a re-entry prompt so the doctor picks up its role from
        # DOCTOR.md immediately rather than waiting for the user to ask.
        # Mirrors what engines/claude-code.sh does on first launch, just
        # adapted for "I've worked with you before" continuity.
        if ! command -v claude >/dev/null 2>&1; then
            echo ""
            echo "  Claude Code is not installed or not in PATH."
            echo "  Install it: npm install -g @anthropic-ai/claude-code"
            echo ""
            exit 1
        fi
        cd "$instance_dir"
        exec claude "Re-entering this doctor instance. Start by reading DOCTOR.md for your role and CLAUDE.md for the personal config of this instance. Then ask what I'd like to work on this session."
        ;;
    version|--version|-V)
        # Useful for bug reports / "what version are you on?" questions.
        # No semver here yet; show git describe (or fallback to short
        # commit sha) so the user has SOMETHING reproducible to share.
        # Distinguish "not a git checkout" from "git missing from PATH"
        # so the user knows which problem they have.
        echo ""
        echo "  thedoc - Emergency Medical Hologram framework"
        echo "  Framework dir: $SCRIPT_DIR"
        if [ -d "$SCRIPT_DIR/.git" ] && command -v git >/dev/null 2>&1; then
            _ver=$(git -C "$SCRIPT_DIR" describe --always --dirty 2>/dev/null || echo unknown)
            _branch=$(git -C "$SCRIPT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)
            echo "  Branch:        $_branch"
            echo "  Commit:        $_ver"
        elif [ -d "$SCRIPT_DIR/.git" ]; then
            echo "  Commit:        (git binary not on PATH - install git to see)"
        else
            echo "  Commit:        (not a git checkout)"
        fi
        echo ""
        ;;
    help|--help|-h)
        echo ""
        echo "  thedoc - Emergency Medical Hologram framework"
        echo ""
        echo "  Commands:"
        echo "    thedoc setup    Create or open a doctor instance (default)"
        echo "    thedoc list     List existing doctor instances"
        echo "    thedoc open     Open an existing instance: thedoc open <name>"
        echo "    thedoc test     Run the wrapper + setup.sh test suites (mirrors CI)"
        echo "    thedoc version  Show framework version (git commit)"
        echo "    thedoc update   git pull the framework to latest"
        echo "    thedoc help     Show this help"
        echo ""
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'thedoc help' for usage."
        exit 1
        ;;
esac
